# ============================================================
# NutriVision AI — Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Application
APP_NAME="NutriVision AI"
APP_VERSION="1.0.0"
APP_ENV=development          # production | development
DEBUG=true                   # Set false in production

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database
# Local: postgresql+asyncpg://user:pass@localhost:5432/dbname
# Railway: just paste the DATABASE_URL from Railway — driver is auto-added
DATABASE_URL=postgresql+asyncpg://nutrivision:nutrivision_pass@localhost:5432/nutrivision_db
# Optional — auto-derived from DATABASE_URL if omitted (only needed for local override)
# DATABASE_URL_SYNC=postgresql+psycopg://nutrivision:nutrivision_pass@localhost:5432/nutrivision_db

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated list of allowed frontend origins
# Production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OpenAI GPT-4o Vision — https://platform.openai.com/api-keys
# Without this key the app uses MockVisionProvider (simulated data)
OPENAI_API_KEY=sk-proj-...

# Redis (optional — for rate limiting persistence)
REDIS_URL=redis://localhost:6379/0

# File Upload
MAX_IMAGE_SIZE_MB=10
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
